{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile for a teacher.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A tweet/post created by a teacher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["authorId", "authorName", "text", "createdAt", "likesCount", "commentsCount"]
    },
    "Like": {
      "title": "Like",
      "description": "A record of a user liking a post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Posts/tweets."
    },
    "/likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Likes on posts. ID is userId_postId."
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on posts."
    }
  }
}
